<UserControl x:Class="YSFileToolsCS.ExtractEXIFControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:YSFileToolsCS"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DockPanel>
        <GroupBox Header="Extract EXIF">
            <DockPanel>
                <Button x:Name="ExtractEXIFButton" Click="ExtractEXIFButton_Click" Margin="5,5,0,0" Width="100" Height="30" DockPanel.Dock="Top">Extract EXIF</Button>
                <Border BorderBrush="Black" BorderThickness="1" Margin="10">
                    <TextBox x:Name="ExtractEXIFText" Padding="5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" IsReadOnly="True"/>
                </Border>
            </DockPanel>
        </GroupBox>
    </DockPanel>
</UserControl>
